modules = ["python-3.11"]
[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[nix]
packages = ["psmisc", "roundcube"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
run = ["sh", "-c", "python3 app.py"]
deploymentTarget = "cloudrun"
